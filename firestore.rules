rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anonymous sign-in is open to anyone on the internet — the web app's
    // Firebase config is public by design — so signedIn() alone is NOT an
    // access decision. It only means "has an auth uid at all", which is the
    // most any client can have before it presents a token.
    function signedIn() {
      return request.auth != null;
    }

    // A client only becomes a *player* once it holds an auth_links binding,
    // which the rule below only lets it create by presenting a real token.
    // Every read gate in this file is keyed to this rather than signedIn(),
    // so the pool's data stays inside the group that was actually handed a
    // link instead of being readable by any passing anonymous session.
    function isPlayer() {
      return signedIn()
        && exists(/databases/$(database)/documents/auth_links/$(request.auth.uid));
    }

    function isOwner(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/auth_links/$(request.auth.uid))
        && get(/databases/$(database)/documents/auth_links/$(request.auth.uid)).data.user_id == userId;
    }

    // Every kind of prediction shares one concept: a deadline, after which
    // it can no longer be modified — and, for the collections that hide
    // data pre-deadline, the same moment is also when it becomes readable
    // by everyone. A match's deadline is its own kickoff_at;
    // special_predictions' deadline is the single admin-set
    // `config/special_predictions.locked_after` (see admin/seed.js —
    // derived from the earliest Round of 16 kickoff).
    function matchDeadlinePassed(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return request.time > m.kickoff_at;
    }

    // Shared by predictions' create and update: a scoreline is an integer
    // goal count, capped at 99 to match the client's own input bound and
    // stay clear of the safe-integer range the app's scoring math assumes.
    function isValidScore(value) {
      return value is int && value >= 0 && value <= 99;
    }

    // Unlike a match, special_predictions' deadline lives in a config doc
    // that might not exist yet, so callers must say what "deadline passed"
    // means in that case. Both call sites below pick the safe direction for
    // what they gate: writes default to true (stay locked — no silently
    // allowing edits with no deadline in place), reads default to false
    // (stay hidden — no revealing picks before an admin has actually set a
    // deadline). Once a real deadline is configured and passes, both callers
    // agree on the same underlying fact and get the same answer.
    function specialPredictionsDeadlinePassed(defaultIfUnset) {
      let configPath = /databases/$(database)/documents/config/special_predictions;
      return exists(configPath)
        ? request.time >= get(configPath).data.locked_after
        : defaultIfUnset;
    }

    // ---- users (fixed schema, read-only to clients) ----
    // Every player can list this collection — the standings page needs
    // everyone's display name. So it must NEVER hold anything secret:
    // a user's token lives in tokens/ and user_links/ below, never here.
    // Firestore rules can't hide individual fields from a document read, so
    // "don't store it" is the only way to keep it out of clients' hands.
    match /users/{userId} {
      allow read: if isPlayer();
      allow write: if false; // admin only, via console / Admin SDK
    }

    // ---- tokens: token -> user_id reverse index (auth plumbing) ----
    // Deliberately still signedIn() and not isPlayer(): this is what a client
    // reads to *become* a player, before any binding exists. Safe because a
    // get() requires already knowing the exact token string (128 random bits,
    // see admin/seed.js) and the collection is never enumerable.
    match /tokens/{token} {
      allow get: if signedIn();  // must already know the exact token string
      allow list: if false;      // never enumerable
      allow write: if false;     // admin only
    }

    // ---- user_links: user_id -> token, so the admin can re-read a player's
    // personal link later (admin/seed.js only prints it once, at creation).
    // Closed to clients outright: the token IS the credential, so anything
    // that can read it can impersonate that player. The Admin SDK bypasses
    // rules, so the admin scripts still reach it.
    match /user_links/{userId} {
      allow read: if false;
      allow write: if false;
    }

    // ---- auth_links: anonymous auth uid -> user_id binding (auth plumbing) ----
    match /auth_links/{authUid} {
      allow get: if signedIn() && request.auth.uid == authUid;
      allow list: if false;

      allow create: if signedIn()
        && request.auth.uid == authUid
        && request.resource.data.keys().hasOnly(['user_id', 'token'])
        && get(/databases/$(database)/documents/tokens/$(request.resource.data.token)).data.user_id
             == request.resource.data.user_id;

      allow update: if false; // binding is immutable; sign out + rebind instead
      allow delete: if false; // admin only (token regeneration / revoke)
    }

    // ---- matches (fixed schema, read-only to clients) ----
    match /matches/{matchId} {
      allow read: if isPlayer();
      allow write: if false; // admin only (fixture load + results entry)
    }

    // ---- predictions (fixed schema) ----
    match /predictions/{predictionId} {
      // own predictions always; others' only after that match kicks off.
      // resource == null when getDoc() targets a prediction that hasn't
      // been saved yet (the normal case on a user's first visit) — there's
      // no resource.data to read then, so derive the owner from the doc ID
      // itself (format "{user_id}_{match_id}"; user_id never contains "_").
      allow read: if isPlayer() && (
        resource == null
          ? isOwner(predictionId.split('_')[0])
          : (isOwner(resource.data.user_id) || matchDeadlinePassed(resource.data.match_id))
      );

      // hasOnly mirrors the update rule's affectedKeys check below: without
      // it, create is the one hole through which a client could park
      // arbitrary extra fields on a doc everyone else reads once it locks.
      allow create: if signedIn()
        && isOwner(request.resource.data.user_id)
        && request.resource.data.keys().hasOnly(
             ['prediction_id', 'user_id', 'match_id', 'predicted_score_a', 'predicted_score_b'])
        && predictionId == request.resource.data.user_id + '_' + request.resource.data.match_id
        && request.resource.data.match_id is string
        && isValidScore(request.resource.data.predicted_score_a)
        && isValidScore(request.resource.data.predicted_score_b)
        && !matchDeadlinePassed(request.resource.data.match_id);

      allow update: if signedIn()
        && isOwner(resource.data.user_id)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['predicted_score_a', 'predicted_score_b'])
        && isValidScore(request.resource.data.predicted_score_a)
        && isValidScore(request.resource.data.predicted_score_b)
        && !matchDeadlinePassed(resource.data.match_id);

      allow delete: if false;
    }

    // ---- special_predictions (fixed schema, one doc per user, doc id = user_id) ----
    // Owner-only up until the deadline passes, then readable by everyone —
    // needed so a future standings page can compute champion/top-scorer
    // points for every user by reading their raw picks directly (see
    // js/scoring-logic.mjs), no server-side precomputation/storage of
    // points involved. Editable (create or update) until
    // specialPredictionsDeadlinePassed() — the deadline the group agreed on
    // (up to the first Round of 16 kickoff), not immediately frozen after
    // the first save.
    match /special_predictions/{userId} {
      allow read: if isOwner(userId) || (isPlayer() && specialPredictionsDeadlinePassed(false));

      allow create: if isOwner(userId)
        && request.resource.data.user_id == userId
        && request.resource.data.champion_pick is string
        && request.resource.data.top_scorer_pick is string
        && request.resource.data.top_scorer_pick_team is string
        && !specialPredictionsDeadlinePassed(true);

      // Same type checks as create, not just the affectedKeys allowlist:
      // these picks are rendered into everyone's standings once revealed, so
      // an update must not be able to swap a pick for a non-string (or an
      // arbitrarily large one) that create would have rejected outright.
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['champion_pick', 'top_scorer_pick', 'top_scorer_pick_team'])
        && request.resource.data.champion_pick is string
        && request.resource.data.top_scorer_pick is string
        && request.resource.data.top_scorer_pick_team is string
        && !specialPredictionsDeadlinePassed(true);

      allow delete: if false;
    }

    // ---- team_rosters (team -> player names, admin-seeded from football-data.org) ----
    // Backs the champion/top-scorer picks form's dropdowns (see admin/seed.js)
    // so users pick from real team/player names instead of typing free text.
    match /team_rosters/{teamName} {
      allow read: if isPlayer();
      allow write: if false; // admin only, via admin/seed.js
    }

    // ---- config (small admin-set values, e.g. the special_predictions deadline) ----
    match /config/{configId} {
      allow read: if isPlayer();
      allow write: if false; // admin only
    }
  }
}
