rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn()
        && exists(/databases/$(database)/documents/auth_links/$(request.auth.uid))
        && get(/databases/$(database)/documents/auth_links/$(request.auth.uid)).data.user_id == userId;
    }

    function matchLocked(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return m.locked == true || request.time > m.kickoff_at;
    }

    // Champion/top-scorer picks can be created or changed up until this
    // deadline (admin/seed.js sets it to the earliest Round of 16 kickoff
    // currently in `matches`) — after that, special_predictions is frozen.
    // Treated as locked by default if the deadline hasn't been configured
    // yet (config/special_predictions doesn't exist) — fails closed rather
    // than silently allowing edits with no deadline in place.
    function specialPredictionsLocked() {
      let configPath = /databases/$(database)/documents/config/special_predictions;
      return !exists(configPath) || request.time >= get(configPath).data.locked_after;
    }

    // Opposite default from specialPredictionsLocked(): defaults to NOT
    // revealed when the deadline hasn't been configured yet, so picks stay
    // hidden until an admin has actually set (and passed) a real deadline —
    // the fail-safe direction here is "stay hidden", not "reveal everyone's
    // picks". Once the same deadline passes, this and specialPredictionsLocked()
    // agree (both true), which is exactly the "editing closes, reveal opens"
    // moment the group's rules describe.
    function specialPredictionsRevealed() {
      let configPath = /databases/$(database)/documents/config/special_predictions;
      return exists(configPath) && request.time >= get(configPath).data.locked_after;
    }

    // ---- users (fixed schema, read-only to clients) ----
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if false; // admin only, via console / Admin SDK
    }

    // ---- tokens: token -> user_id reverse index (auth plumbing) ----
    match /tokens/{token} {
      allow get: if signedIn();  // must already know the exact token string
      allow list: if false;      // never enumerable
      allow write: if false;     // admin only
    }

    // ---- auth_links: anonymous auth uid -> user_id binding (auth plumbing) ----
    match /auth_links/{authUid} {
      allow get: if signedIn() && request.auth.uid == authUid;
      allow list: if false;

      allow create: if signedIn()
        && request.auth.uid == authUid
        && request.resource.data.keys().hasOnly(['user_id', 'token'])
        && get(/databases/$(database)/documents/tokens/$(request.resource.data.token)).data.user_id
             == request.resource.data.user_id;

      allow update: if false; // binding is immutable; sign out + rebind instead
      allow delete: if false; // admin only (token regeneration / revoke)
    }

    // ---- matches (fixed schema, read-only to clients) ----
    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if false; // admin only (fixture load + results entry)
    }

    // ---- predictions (fixed schema) ----
    match /predictions/{predictionId} {
      // own predictions always; others' only after that match kicks off.
      // resource == null when getDoc() targets a prediction that hasn't
      // been saved yet (the normal case on a user's first visit) — there's
      // no resource.data to read then, so derive the owner from the doc ID
      // itself (format "{user_id}_{match_id}"; user_id never contains "_").
      allow read: if signedIn() && (
        resource == null
          ? isOwner(predictionId.split('_')[0])
          : (isOwner(resource.data.user_id) || matchLocked(resource.data.match_id))
      );

      allow create: if signedIn()
        && isOwner(request.resource.data.user_id)
        && predictionId == request.resource.data.user_id + '_' + request.resource.data.match_id
        && request.resource.data.match_id is string
        && request.resource.data.predicted_score_a is int
        && request.resource.data.predicted_score_a >= 0
        && request.resource.data.predicted_score_b is int
        && request.resource.data.predicted_score_b >= 0
        && !matchLocked(request.resource.data.match_id);

      allow update: if signedIn()
        && isOwner(resource.data.user_id)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['predicted_score_a', 'predicted_score_b'])
        && !matchLocked(resource.data.match_id);

      allow delete: if false;
    }

    // ---- special_predictions (fixed schema, one doc per user, doc id = user_id) ----
    // Owner-only up until the deadline passes, then readable by everyone —
    // needed so a future standings page can compute champion/top-scorer
    // points for every user by reading their raw picks directly (see
    // js/scoring-logic.mjs), no server-side precomputation/storage of
    // points involved. Editable (create or update) until
    // specialPredictionsLocked() — the deadline the group agreed on (up to
    // the first Round of 16 kickoff), not immediately frozen after the
    // first save.
    match /special_predictions/{userId} {
      allow read: if isOwner(userId) || specialPredictionsRevealed();

      allow create: if isOwner(userId)
        && request.resource.data.user_id == userId
        && request.resource.data.champion_pick is string
        && request.resource.data.top_scorer_pick is string
        && !specialPredictionsLocked();

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['champion_pick', 'top_scorer_pick'])
        && !specialPredictionsLocked();

      allow delete: if false;
    }

    // ---- team_rosters (team -> player names, admin-seeded from football-data.org) ----
    // Backs the champion/top-scorer picks form's dropdowns (see admin/seed.js)
    // so users pick from real team/player names instead of typing free text.
    match /team_rosters/{teamName} {
      allow read: if signedIn();
      allow write: if false; // admin only, via admin/seed.js
    }

    // ---- config (small admin-set values, e.g. the special_predictions deadline) ----
    match /config/{configId} {
      allow read: if signedIn();
      allow write: if false; // admin only
    }
  }
}
